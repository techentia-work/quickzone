# 🌐 UNIVERSAL IGNORE (applies to all folders)

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
**/.env
**/.env.*

# IDE / Editor
.vscode/
.idea/
*.iml

# Build outputs (general)
build/
**/build/
dist/
**/dist/
coverage/
**/.cache/
.cache/

# Dependency directories
node_modules/
**/node_modules/

# Temporary files
*.tmp
*.swp
*.swo
*.bak
*.orig

# 🧠 NODE.JS / NEXT.JS / REACT PROJECTS (admin, web, server)

# Next.js build artifacts
.next/
**/.next/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Yarn / PnP
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Deployment platforms
.vercel/
.netlify/
firebase-debug.log
firebase-debug.*.log

# 📱 FLUTTER / DART PROJECT (user_app)

# Flutter & Dart build artifacts
user_app/build/
user_app/.dart_tool/
user_app/.packages
user_app/.flutter-plugins
user_app/.flutter-plugins-dependencies
user_app/.metadata
user_app/.pub-cache/
user_app/.pub/
user_app/pubspec.lock

# iOS
user_app/ios/Flutter/Flutter.framework
user_app/ios/Flutter/Flutter.podspec
user_app/ios/Flutter/Generated.xcconfig
user_app/ios/Flutter/App.framework
user_app/ios/Flutter/ephemeral/
user_app/ios/Pods/
user_app/ios/Runner.xcworkspace/
user_app/ios/ServiceDefinitions.json
user_app/ios/Podfile.lock

# macOS
user_app/macos/Pods/
user_app/macos/Flutter/ephemeral/
user_app/macos/Flutter/Flutter-Debug.xcconfig
user_app/macos/Flutter/Flutter-Release.xcconfig

# Android
user_app/android/.gradle/
user_app/android/app/build/
user_app/android/local.properties
user_app/android/key.properties

# Windows / Linux Flutter builds
user_app/windows/flutter/ephemeral/
user_app/linux/flutter/ephemeral/

# Xcode user data & derived data
*.mode1v3
*.mode2v3
*.perspectivev3
*.xcuserstate
*.xcworkspace
xcuserdata/
DerivedData/

# 🧩 OPTIONAL: GLOBAL TOOLING / MISC

# Firebase / Google Services files (uncomment if you commit manually)
# google-services.json
# GoogleService-Info.plist

# VSCode / JetBrains local history
.history/
.localhistory/

# Lint cache
.eslintcache

# Package manager lockfiles (optional, if you prefer reproducible builds, keep them)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ✅ Server uploads
server/uploads/
uploads/

